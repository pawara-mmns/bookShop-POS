<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="bookShop.MainWindow"
        Title="Login"
        Width="900"
        Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid ColumnDefinitions="*,420">
        
        <Border Background="#1E293B" Padding="50">
            <StackPanel VerticalAlignment="Center" Spacing="16">
                <TextBlock Text="Welcome Back"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Login to access your BookShop desktop application."
                           FontSize="16"
                           Foreground="#CBD5E1"
                           TextWrapping="Wrap"/>

                <Border Background="#334155"
                        CornerRadius="18"
                        Padding="20"
                        Margin="0,25,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="BookShop Features"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="• Manage books&#x0A;• Track orders&#x0A;• Handle customers&#x0A;• View dashboard"
                                   Foreground="#E2E8F0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#F8FAFC">
            <Border Width="320"
                    Padding="28"
                    CornerRadius="20"
                    Background="White"
                    BoxShadow="0 10 30 0 #30000000"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel Spacing="14">
                    <TextBlock Text="Login"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#0F172A"/>

                    <TextBlock Text="Enter your account details"
                               HorizontalAlignment="Center"
                               Foreground="#64748B"/>

                    <TextBlock Text="Username"
                               Margin="0,10,0,0"
                               FontWeight="SemiBold"
                               Foreground="#334155"/>

                    <TextBox x:Name="UsernameBox"
                             Watermark="Enter your username"
                             Padding="12"/>

                    <TextBlock Text="Password"
                               Margin="0,6,0,0"
                               FontWeight="SemiBold"
                               Foreground="#334155"/>

                    <TextBox x:Name="PasswordBox"
                             PasswordChar="*"
                             Watermark="Enter your password"
                             Padding="12"/>

                    <Button x:Name="LoginButton"
                            Content="Sign In"
                            Height="42"
                            Margin="0,12,0,0"
                            FontWeight="Bold"/>

                    <TextBlock x:Name="ResultText"
                               Text=""
                               Foreground="#DC2626"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
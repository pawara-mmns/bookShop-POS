<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        x:Class="bookShop.MainWindow"
        Title="NovaBooks POS Login"
        Width="900"
        Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB">

    <Grid RowDefinitions="*,Auto">
        
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            
            <!-- Logo area -->
            <Border Background="#4F46E5" Width="56" Height="56" CornerRadius="14" HorizontalAlignment="Center" Margin="0,0,0,8" BoxShadow="0 6 16 0 #334F46E5">
                <!-- Book icon -->
                <svg:Svg Path="/Assets/Icons/book.svg" Width="28" Height="28" Css=".icon { fill: #FFFFFF; }" />
            </Border>

            <TextBlock Text="NovaBooks POS" FontSize="26" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" />
            <TextBlock Text="Sign in to access the management system" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <!-- Login Card -->
            <Border Background="White" Width="400" CornerRadius="12" Padding="32" BoxShadow="0 10 30 0 #0D000000">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Email Address" FontWeight="SemiBold" FontSize="13" Foreground="#374151" />
                        <TextBox x:Name="UsernameBox" Watermark="Enter your email" CornerRadius="6" VerticalContentAlignment="Center" MinHeight="42" Padding="12,0" Background="White" BorderBrush="#D1D5DB" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Password" FontWeight="SemiBold" FontSize="13" Foreground="#374151" />
                        <TextBox x:Name="PasswordBox" Watermark="Enter your password" PasswordChar="•" CornerRadius="6" VerticalContentAlignment="Center" MinHeight="42" Padding="12,0" Background="White" BorderBrush="#D1D5DB" FontFamily="Arial" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,4">
                        <CheckBox Content="Remember me" Foreground="#4B5563" FontSize="13" VerticalAlignment="Center" Grid.Column="0"/>
                        <Button Grid.Column="1" Content="Forgot password?" Foreground="#4F46E5" FontSize="13" FontWeight="SemiBold" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Center" Cursor="Hand" />
                    </Grid>

                    <TextBlock x:Name="ResultText" Foreground="#EF4444" FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,-4,0,0"/>

                    <Button x:Name="LoginButton" Content="Sign In" Background="#4F46E5" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MinHeight="44" CornerRadius="6" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,0" Cursor="Hand" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="1" Text="© 2026 NovaBooks Systems. All rights reserved." Foreground="#9CA3AF" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,32" />

    </Grid>
</Window>
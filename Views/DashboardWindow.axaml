<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="bookShop.Views.DashboardWindow"
        Title="NovaBooks Dashboard"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9">

    <Window.Styles>
        <Style Selector="Border.nav-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style Selector="Border.nav-item TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
        </Style>

        <Style Selector="Border.nav-item.selected">
            <Setter Property="Background" Value="#F3F4F6"/>
        </Style>

        <Style Selector="Border.nav-item.selected TextBlock">
            <Setter Property="Foreground" Value="#4F46E5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="250,*">
        
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="70,*,Auto">
                
                <!-- Logo -->
                <Border Grid.Row="0" Padding="24,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <Border Background="#4F46E5" Width="32" Height="32" CornerRadius="8" HorizontalAlignment="Center">
                            <Viewbox Width="16" Height="16">
                                <Path Fill="White" Data="M2,3C2,2.44772 2.44772,2 3,2H9.5C10.6046,2 11.5,2.89543 11.5,4V21C11.5,21.5523 11.0523,22 10.5,22H3C2.44772,22 2,21.5523 2,21V3ZM12.5,4C12.5,2.89543 13.3954,2 14.5,2H21C21.5523,2 22,2.44772 22,3V21C22,21.5523 21.5523,22 21,22H13.5C12.9477,22 12.5,21.5523 12.5,21V4ZM13.5,20H20V4H14.5C13.6716,4 13,4.67157 13,5.5V20.25 C13.1611,20.0886 13.3444,20 13.5,20ZM10.5,20C10.6556,20 10.8389,20.0886 11,20.25V5.5C11,4.67157 10.3284,4 9.5,4H4V20H10.5Z"/>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="NovaBooks" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" Padding="16,10">
                    <StackPanel Spacing="6">
                        <Border x:Name="NavDashboard" Classes="nav-item selected" Tag="Dashboard" PointerPressed="NavItem_PointerPressed">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⊞" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="NavPos" Classes="nav-item" Tag="POS Billing" PointerPressed="NavItem_PointerPressed">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🖩" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="POS Billing" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="NavInventory" Classes="nav-item" Tag="Book Inventory" PointerPressed="NavItem_PointerPressed">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="📖" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Book Inventory" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="NavCustomers" Classes="nav-item" Tag="Customers" PointerPressed="NavItem_PointerPressed">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="👥" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Customers" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="NavSuppliers" Classes="nav-item" Tag="Suppliers" PointerPressed="NavItem_PointerPressed">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🚚" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Suppliers" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom Action -->
                <Border Grid.Row="2" Padding="24" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" PointerPressed="SignOut_PointerPressed">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="↪" Foreground="#EF4444" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="Sign Out" Foreground="#EF4444" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" RowDefinitions="70,*">
            
            <!-- Top Header -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="≡" FontSize="20" Foreground="#4B5563" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HeaderTitle" Text="Dashboard" FontSize="20" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <TextBox Watermark="Global search..." Width="240" CornerRadius="8" Background="#F3F4F6" BorderBrush="Transparent" Padding="10,8"/>
                        <TextBlock Text="🔔" FontSize="18" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <Border Background="#E0E7FF" Width="36" Height="36" CornerRadius="18">
                            <TextBlock Text="AD" Foreground="#4F46E5" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl x:Name="PageHost" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
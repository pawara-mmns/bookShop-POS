<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="bookShop.Views.Dialogs.EditCashierWindow"
        Title="Edit Cashier"
        Width="520"
        Height="660"
        WindowStartupLocation="CenterOwner"
        Background="#F9FAFB"
        CanResize="False">

    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Margin="16" Padding="20">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14">

            <TextBlock Grid.Row="0" Text="Edit Cashier" FontSize="20" FontWeight="Bold" Foreground="#111827" />

            <StackPanel Grid.Row="1" Spacing="12">

                <StackPanel Spacing="6">
                    <TextBlock Text="Username" FontWeight="SemiBold" FontSize="13" Foreground="#374151" />
                    <TextBox x:Name="UsernameBox" IsReadOnly="True" CornerRadius="8" MinHeight="40" Padding="12,8" Background="#F3F4F6" BorderBrush="#D1D5DB" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="New Password (optional)" FontWeight="SemiBold" FontSize="13" Foreground="#374151" />
                    <TextBox x:Name="PasswordBox" PasswordChar="•" CornerRadius="8" MinHeight="40" Padding="12,8" Background="White" BorderBrush="#D1D5DB" />
                </StackPanel>

                <Border Height="1" Background="#E5E7EB" />

                <TextBlock Text="Access (POS Billing is always available)" FontWeight="SemiBold" FontSize="13" Foreground="#111827" />

                <CheckBox x:Name="DashboardCheck" Content="Dashboard" Foreground="#4B5563" FontSize="13" />
                <CheckBox x:Name="OrdersCheck" Content="Orders" Foreground="#4B5563" FontSize="13" />
                <CheckBox x:Name="InventoryCheck" Content="Book Inventory" Foreground="#4B5563" FontSize="13" />
                <CheckBox x:Name="CustomersCheck" Content="Customers" Foreground="#4B5563" FontSize="13" />
                <CheckBox x:Name="SuppliersCheck" Content="Suppliers" Foreground="#4B5563" FontSize="13" />
                <CheckBox x:Name="ReportsCheck" Content="Reports" Foreground="#4B5563" FontSize="13" />
                <CheckBox x:Name="DiscountCardsCheck" Content="Discount Cards" Foreground="#4B5563" FontSize="13" />

                <TextBlock x:Name="ErrorText" Text="" Foreground="#EF4444" FontSize="13" TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Content="Cancel" Background="White" Foreground="#111827" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="14,10" FontWeight="SemiBold" Click="Cancel_Click" />
                <Button Grid.Column="1" Content="Save" Background="#4F46E5" Foreground="White" CornerRadius="8" Padding="14,10" FontWeight="SemiBold" Click="Save_Click" />
            </Grid>

        </Grid>
    </Border>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:bookShop.Views.Pages"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:Class="bookShop.Views.Pages.CashiersPage"
             Background="Transparent">

    <Grid RowDefinitions="Auto,*" Margin="32">

        <!-- Header Row -->
        <Grid Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Background="#E0E7FF" Width="36" Height="36" CornerRadius="10">
                    <svg:Svg Path="/Assets/Icons/customers.svg" Width="16" Height="16" Css=".icon { fill: #4F46E5; }" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Cashiers" FontSize="22" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1" Content="+  Add New" Background="#4F46E5" Foreground="White" CornerRadius="8" Padding="16,10" FontWeight="SemiBold" Click="AddCashier_Click" />
        </Grid>

        <!-- Card -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid RowDefinitions="Auto,*">

                <!-- Table Header -->
                <Border Grid.Row="0" Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,12">
                    <Grid ColumnDefinitions="80,2*,3*,120,Auto" ColumnSpacing="12">
                        <TextBlock Text="ID" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" />
                        <TextBlock Grid.Column="1" Text="USERNAME" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" />
                        <TextBlock Grid.Column="2" Text="ACCESS" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" />
                        <TextBlock Grid.Column="3" Text="ACTIVE" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="ACTIONS" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Table Body -->
                <ScrollViewer Grid.Row="1" Padding="16">
                    <ItemsControl x:Name="CashiersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:CashierRow">
                                <Border Background="Transparent" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid ColumnDefinitions="80,2*,3*,120,Auto" ColumnSpacing="12">
                                        <TextBlock Text="{Binding Id}" FontSize="13" FontWeight="SemiBold" Foreground="#111827" />
                                        <TextBlock Grid.Column="1" Text="{Binding UserName}" FontSize="13" FontWeight="SemiBold" Foreground="#111827" />
                                        <TextBlock Grid.Column="2" Text="{Binding AccessSummary}" FontSize="13" Foreground="#6B7280" TextWrapping="NoWrap" />

                                        <CheckBox Grid.Column="3"
                                                  IsChecked="{Binding IsActive}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Checked="ActiveToggle_Changed"
                                                  Unchecked="ActiveToggle_Changed" />

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                            <Button Background="Transparent" BorderThickness="0" Padding="6" Click="EditCashier_Click" ToolTip.Tip="Edit">
                                                <svg:Svg Path="/Assets/Icons/edit.svg" Width="16" Height="16" Css=".icon { fill: #9CA3AF; }" />
                                            </Button>
                                            <Button Background="Transparent" BorderThickness="0" Padding="6" Click="DeleteCashier_Click" ToolTip.Tip="Delete">
                                                <svg:Svg Path="/Assets/Icons/trash.svg" Width="16" Height="16" Css=".icon { fill: #9CA3AF; }" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>

    </Grid>
</UserControl>

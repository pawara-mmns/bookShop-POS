<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="bookShop.Views.Pages.PosBillingPage">

    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Margin="32" Padding="24">
        <StackPanel Spacing="8">
            <TextBlock Text="POS Billing" FontSize="22" FontWeight="Bold" Foreground="#111827" />
            <TextBlock Text="This section is ready for UI wiring." FontSize="14" Foreground="#6B7280" />
        </StackPanel>
    </Border>
</UserControl>

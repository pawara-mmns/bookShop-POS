<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:bookShop.Models"
             xmlns:local="clr-namespace:bookShop.Views.Pages"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:Class="bookShop.Views.Pages.PosBillingPage">

    <UserControl.Styles>
        <Style Selector="Button.pay-option">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.pay-option.selected">
            <Setter Property="BorderBrush" Value="#4F46E5"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="#4F46E5"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="32">

        <!-- Header Row -->
        <Grid Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Background="#E0E7FF" Width="36" Height="36" CornerRadius="10">
                    <svg:Svg Path="/Assets/Icons/pos.svg" Width="16" Height="16" Css=".icon { fill: #4F46E5; }" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="POS Billing" FontSize="22" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="2*,1*" ColumnSpacing="24">

            <!-- Left: Search + Current Order -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,*">

                    <!-- Search Row -->
                    <Border Grid.Row="0" Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBox x:Name="SearchBox" Watermark="Search books by title, author, or ISBN" CornerRadius="8" Background="White" BorderBrush="#D1D5DB" Padding="12,10" TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown" />
                            <Button Grid.Column="1" Content="+  Add Custom Item" Background="#4F46E5" Foreground="White" CornerRadius="8" Padding="16,10" FontWeight="SemiBold" Click="AddCustomItem_Click" />
                        </Grid>
                    </Border>

                    <!-- Search Results (shown only when searching) -->
                    <Border Grid.Row="1" x:Name="SearchResultsContainer" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16" IsVisible="False">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Results" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" />
                            <ScrollViewer MaxHeight="180">
                                <ItemsControl x:Name="SearchResultsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:Books">
                                            <Border Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="#111827" />
                                                        <TextBlock Text="{Binding Author}" FontSize="12" Foreground="#6B7280" />
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <TextBlock Text="{Binding ISBN}" FontSize="12" Foreground="#6B7280" />
                                                            <TextBlock Text="•" FontSize="12" Foreground="#D1D5DB" />
                                                            <TextBlock Text="{Binding Stock, StringFormat={}{0} in stock}" FontSize="12" Foreground="#6B7280" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                                                        <TextBlock Text="{Binding Price, StringFormat={}LKR {0:0.00}}" FontSize="13" Foreground="#111827" HorizontalAlignment="Right" />
                                                        <Button Content="Add" Background="#4F46E5" Foreground="White" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" Click="AddBookToOrder_Click" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Current Order Header -->
                    <Border Grid.Row="2" Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,14">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Current Order" FontSize="16" FontWeight="Bold" Foreground="#111827" />
                            <TextBlock Grid.Column="1" x:Name="ItemsCountText" Text="0 items" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Order Table -->
                    <Grid Grid.Row="3" RowDefinitions="Auto,*">

                        <!-- Table Header -->
                        <Border Grid.Row="0" Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,12">
                            <Grid ColumnDefinitions="2.4*,1.2*,1.1*,1.1*,Auto" ColumnSpacing="12">
                                <TextBlock Text="ITEM" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" />
                                <TextBlock Grid.Column="1" Text="QTY" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="PRICE (LKR)" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="TOTAL (LKR)" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="4" Text="" />
                            </Grid>
                        </Border>

                        <!-- Table Body -->
                        <ScrollViewer Grid.Row="1" Padding="16">
                            <ItemsControl x:Name="OrderItemsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:PosLineItem">
                                        <Border Background="Transparent" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,12">
                                            <Grid ColumnDefinitions="2.4*,1.2*,1.1*,1.1*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding ItemName}" FontSize="13" FontWeight="SemiBold" Foreground="#111827" />
                                                    <TextBlock Text="{Binding ItemCode}" FontSize="12" Foreground="#6B7280" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                                    <Button Content="-" Width="28" Height="28" CornerRadius="14" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" Click="DecreaseQty_Click" />
                                                    <TextBlock Text="{Binding Quantity}" Width="24" TextAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#111827" />
                                                    <Button Content="+" Width="28" Height="28" CornerRadius="14" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" Click="IncreaseQty_Click" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding UnitPriceDisplay}" FontSize="13" Foreground="#6B7280" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="{Binding LineTotalDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="#111827" HorizontalAlignment="Right" VerticalAlignment="Center" />

                                                <Button Grid.Column="4" Background="Transparent" BorderThickness="0" Padding="6" Click="RemoveLine_Click" ToolTip.Tip="Remove">
                                                    <svg:Svg Path="/Assets/Icons/trash.svg" Width="16" Height="16" Css=".icon { fill: #9CA3AF; }" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Border>

            <!-- Right: Order Summary -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="12">

                    <TextBlock Grid.Row="0" Text="Order Summary" FontSize="16" FontWeight="Bold" Foreground="#111827" />

                    <ComboBox Grid.Row="1" x:Name="CustomerCombo" CornerRadius="8" Background="White" BorderBrush="#D1D5DB" MinHeight="40" SelectionChanged="CustomerCombo_SelectionChanged" />

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBox x:Name="DiscountCodeBox" Watermark="Discount Code" CornerRadius="8" Background="White" BorderBrush="#D1D5DB" Padding="12,10" />
                        <Button Grid.Column="1" Content="Apply" Background="White" Foreground="#111827" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Padding="16,10" FontWeight="SemiBold" Click="ApplyDiscount_Click" />
                    </Grid>

                    <Border Grid.Row="3" Height="1" Background="#E5E7EB" />

                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
                        <TextBlock Text="Subtotal" FontSize="13" Foreground="#6B7280" />
                        <TextBlock Grid.Column="1" x:Name="SubtotalText" Text="LKR 0.00" FontSize="13" Foreground="#6B7280" />
                    </Grid>

                    <Grid Grid.Row="5" ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="TaxLabel" Text="Tax (8%)" FontSize="13" Foreground="#6B7280" />
                        <TextBlock Grid.Column="1" x:Name="TaxText" Text="LKR 0.00" FontSize="13" Foreground="#6B7280" />
                    </Grid>

                    <Grid Grid.Row="6" ColumnDefinitions="*,Auto">
                        <TextBlock Text="Discount" FontSize="13" Foreground="#6B7280" />
                        <TextBlock Grid.Column="1" x:Name="DiscountText" Text="-LKR 0.00" FontSize="13" Foreground="#10B981" />
                    </Grid>

                    <Grid Grid.Row="7" ColumnDefinitions="*,Auto">
                        <TextBlock Text="Total" FontSize="14" FontWeight="Bold" Foreground="#111827" />
                        <TextBlock Grid.Column="1" x:Name="TotalText" Text="LKR 0.00" FontSize="22" FontWeight="Bold" Foreground="#4F46E5" />
                    </Grid>

                    <StackPanel Grid.Row="8" Spacing="10">
                        <TextBlock Text="Payment Method" FontSize="13" FontWeight="SemiBold" Foreground="#111827" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button x:Name="CardButton" Classes="pay-option selected" Content="Card" Click="PaymentCard_Click" />
                            <Button Grid.Column="1" x:Name="CashButton" Classes="pay-option" Content="Cash" Click="PaymentCash_Click" />
                        </Grid>

                        <TextBlock x:Name="ErrorText" Text="" Foreground="#EF4444" FontSize="13" TextWrapping="Wrap" />

                        <Button Content="Complete Sale" Background="#4F46E5" Foreground="White" CornerRadius="10" Padding="18,12" FontWeight="SemiBold" Click="CompleteSale_Click" />
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
